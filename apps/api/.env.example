NODE_ENV=development
PORT=4000
API_PREFIX=api

# Postgres
# Local Docker Postgres:
# DATABASE_URL="postgresql://dautaytoy:dautaytoy_dev_password@localhost:5432/dautaytoy?schema=public"
# DIRECT_URL="postgresql://dautaytoy:dautaytoy_dev_password@localhost:5432/dautaytoy?schema=public"
#
# Supabase: DATABASE_URL uses the pooled connection (port 6543, PgBouncer in
# transaction mode) for the running app; DIRECT_URL uses the direct connection
# (port 5432) which Prisma needs for `migrate`/`db push` since PgBouncer's
# transaction mode doesn't support prepared statements or DDL sessions well.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_REFRESH_EXPIRES_IN="30d"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Cloudflare R2 (S3-compatible) — used from Phase 2+ media modules
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="dautaytoy-media"
R2_PUBLIC_URL=""

# Outbound email (Resend) — used by EmailProcessor (password reset). Left blank, the app
# still boots fine; sends are skipped with a logged warning instead of failing the job.
RESEND_API_KEY=""
EMAIL_FROM="DauTayToy Store <no-reply@dautaytoystore.vn>"

# VNPay payment gateway — used when checkout's paymentMethod is "VNPAY" (COD needs none of
# this). Left blank, the app still boots fine; only picking VNPAY at checkout then fails with a
# clear error instead of COD checkout breaking. Get sandbox TMN_CODE/HASH_SECRET by registering
# at https://sandbox.vnpayment.vn/devreg/. VNPAY_RETURN_URL must be this API's own public URL
# (not the frontend's) + "/api/payments/vnpay/return" — e.g. for local dev,
# "http://localhost:4000/api/payments/vnpay/return". Separately, the IPN URL
# ("<this API's public URL>/api/payments/vnpay/ipn") must be registered once in the VNPay
# merchant dashboard itself — that step can't be done via env vars/code.
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_PAYMENT_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:4000/api/payments/vnpay/return"

# MoMo payment gateway — used when checkout's paymentMethod is "MOMO". Left blank, the app still
# boots fine; only picking MOMO at checkout then fails with a clear error. MoMo does NOT publish
# shared public test credentials (unlike some gateways) — register at https://business.momo.vn
# or email merchant.care@momo.vn for a partnerCode/accessKey/secretKey triple. Unlike VNPay,
# there's no separate merchant-dashboard IPN registration step — MOMO_IPN_URL travels with every
# create-payment request — but that also means a typo/unreachable host is invisible until MoMo's
# own delivery attempt silently fails, so double-check it's a publicly reachable, TLS-valid host
# before the first real sandbox transaction.
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"
MOMO_REDIRECT_URL="http://localhost:4000/api/payments/momo/return"
MOMO_IPN_URL="http://localhost:4000/api/payments/momo/ipn"

# Rate limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
