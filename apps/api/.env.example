NODE_ENV=development
PORT=4000
API_PREFIX=api

# Postgres
# Local Docker Postgres:
# DATABASE_URL="postgresql://dautaytoy:dautaytoy_dev_password@localhost:5432/dautaytoy?schema=public"
# DIRECT_URL="postgresql://dautaytoy:dautaytoy_dev_password@localhost:5432/dautaytoy?schema=public"
#
# Supabase: DATABASE_URL uses the pooled connection (port 6543, PgBouncer in
# transaction mode) for the running app; DIRECT_URL uses the direct connection
# (port 5432) which Prisma needs for `migrate`/`db push` since PgBouncer's
# transaction mode doesn't support prepared statements or DDL sessions well.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_REFRESH_EXPIRES_IN="30d"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Cloudflare R2 (S3-compatible) — used from Phase 2+ media modules
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="dautaytoy-media"
R2_PUBLIC_URL=""

# Outbound email (Resend) — used by EmailProcessor (password reset). Left blank, the app
# still boots fine; sends are skipped with a logged warning instead of failing the job.
RESEND_API_KEY=""
EMAIL_FROM="DauTayToy Store <no-reply@dautaytoystore.vn>"

# Rate limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
